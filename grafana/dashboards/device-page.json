      "collapsed": false,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 0
      },
      "id": 1,
      "title": "Live Status \u2014 $device",
      "type": "row"
    },
    {
      "datasource": {
        "type": "influxdb",
        "uid": "influxdb_v2"
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "value"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "blue",
                "value": null
              }
            ]
          },
          "mappings": [
            {
              "options": {
                "Streaming": {
                  "color": "green",
                  "index": 0,
                  "text": "Streaming"
                },
                "Idle": {
                  "color": "yellow",
                  "index": 1,
                  "text": "Idle"
                },
                "Disconnected": {
                  "color": "red",
                  "index": 2,
                  "text": "Disconnected"
                }
              },
              "type": "value"
            }
          ],
          "type": "string"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 4,
        "w": 4,
        "x": 0,
        "y": 1
      },
      "id": 2,
      "options": {
        "reduceOptions": {
          "calcs": [
            "last"
          ],
          "fields": "/^status$/"
        },
        "orientation": "auto",
        "textMode": "value",
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center"
      },
      "title": "Status",
      "type": "stat",
      "targets": [
        {
          "datasource": {
            "type": "influxdb",
            "uid": "influxdb_v2"
          },
          "query": "from(bucket: v.defaultBucket)\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r._measurement == \"${device}\")\n  |> filter(fn: (r) => r._field == \"status\")\n  |> last()",
          "refId": "A"
        }
      ],
      "transformations": [
        {
          "id": "filterFieldsByName",
          "options": {
            "include": {
              "names": [
                "status"
              ]
            }
          }
        }
      ]
    },
    {
      "datasource": {
        "type": "influxdb",
        "uid": "influxdb_v2"
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "blue",
                "value": null
              }
            ]
          },
          "unit": "Mbits",
          "min": 0,
          "max": 15
        },
        "overrides": []
      },
      "gridPos": {
        "h": 4,
        "w": 5,
        "x": 4,
        "y": 1
      },
      "id": 3,
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
