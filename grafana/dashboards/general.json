          "query": "from(bucket: v.defaultBucket)\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r._field == \"videoBitrate\")\n  |> filter(fn: (r) => r._measurement =~ /^WP[0-9]+$/)\n  |> map(fn: (r) => ({r with _value: r._value / 1000000.0}))\n  |> yield(name: \"videoBitrate\")",
          "refId": "A"
