      "title": "Download Speed",
      "type": "stat",
      "targets": [
        {
          "datasource": {
            "type": "influxdb",
            "uid": "influxdb_v2"
          },
          "query": "from(bucket: v.defaultBucket)\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r._measurement == \"SpeedTest\")\n  |> filter(fn: (r) => r._field == \"download\")\n  |> last()\n  |> map(fn: (r) => ({r with _value: r._value * 8.0 / 1000000.0}))",
          "refId": "A"
        }
      ]
    },
