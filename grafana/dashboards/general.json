      "options": {
        "footer": {
          "show": false
        },
        "showHeader": true,
        "sortBy": [
          {
            "displayName": "Measurement",
            "desc": false
          }
        ]
      },
      "title": "All Devices \u2014 Latest Status",
      "type": "table",
      "transformations": [
        {
          "id": "merge",
          "options": {}
        },
        {
          "id": "organize",
          "options": {
            "renameByName": {
              "_measurement": "Device",
              "_value": "Status",
              "_time": "Last Seen"
            }
          }
        }
      ],
      "targets": [
        {
          "datasource": {
            "type": "influxdb",
            "uid": "influxdb_v2"
          },
          "query": "union(tables: [\n  from(bucket: v.defaultBucket) |> range(start: v.timeRangeStart, stop: v.timeRangeStop) |> filter(fn: (r) => r._measurement == \"WP1\") |> filter(fn: (r) => r._field == \"status\") |> last(),\n  from(bucket: v.defaultBucket) |> range(start: v.timeRangeStart, stop: v.timeRangeStop) |> filter(fn: (r) => r._measurement == \"WP2\") |> filter(fn: (r) => r._field == \"status\") |> last(),\n  from(bucket: v.defaultBucket) |> range(start: v.timeRangeStart, stop: v.timeRangeStop) |> filter(fn: (r) => r._measurement == \"WP3\") |> filter(fn: (r) => r._field == \"status\") |> last(),\n  from(bucket: v.defaultBucket) |> range(start: v.timeRangeStart, stop: v.timeRangeStop) |> filter(fn: (r) => r._measurement == \"WP4\") |> filter(fn: (r) => r._field == \"status\") |> last(),\n  from(bucket: v.defaultBucket) |> range(start: v.timeRangeStart, stop: v.timeRangeStop) |> filter(fn: (r) => r._measurement == \"WP5\") |> filter(fn: (r) => r._field == \"status\") |> last(),\n  from(bucket: v.defaultBucket) |> range(start: v.timeRangeStart, stop: v.timeRangeStop) |> filter(fn: (r) => r._measurement == \"WP6\") |> filter(fn: (r) => r._field == \"status\") |> last(),\n  from(bucket: v.defaultBucket) |> range(start: v.timeRangeStart, stop: v.timeRangeStop) |> filter(fn: (r) => r._measurement == \"WP7\") |> filter(fn: (r) => r._field == \"status\") |> last(),\n  from(bucket: v.defaultBucket) |> range(start: v.timeRangeStart, stop: v.timeRangeStop) |> filter(fn: (r) => r._measurement == \"WP8\") |> filter(fn: (r) => r._field == \"status\") |> last()\n])",
          "refId": "A"
        }
      ]
