      "title": "Interface Traffic Rate (bytes/s)",
      "type": "timeseries",
      "targets": [
        {
          "datasource": {
            "type": "influxdb",
            "uid": "influxdb_v2"
          },
          "query": "from(bucket: v.defaultBucket)\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r._measurement == \"NetworkInterfaces\")\n  |> filter(fn: (r) => r._field == \"bytes_sent\" or r._field == \"bytes_recv\")\n  |> derivative(unit: 1s, nonNegative: true)\n  |> yield(name: \"traffic\")",
          "refId": "A"
        }
      ]
    },
