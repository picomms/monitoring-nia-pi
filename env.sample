TZ=Europe/Dublin
HOST_ID=cherry

# Image pins (override only when upgrading intentionally)
PROMETHEUS_VERSION=v3.13.1
GRAFANA_VERSION=13.0
NODE_EXPORTER_VERSION=v1.12.0
CLOUDFLARED_VERSION=2026.7.1

# Published ports (LAN access)
PROMETHEUS_PORT=9090
GRAFANA_PORT=3000

# Grafana
GF_ADMIN_USER=admin
GF_ADMIN_PASSWORD=changeme
# LAN fallback used when GRAFANA_ROOT_URL is unset.
GRAFANA_HOST=localhost
# Public URL used behind Cloudflare Tunnel / Access.
GRAFANA_ROOT_URL=https://mon-grafana.cothrom.ie

# Cloudflare Tunnel (enable with: just up-tunnel)
# Hostnames are managed in Zero Trust with a mon- prefix under cothrom.ie:
# - mon-grafana.cothrom.ie -> http://grafana:3000 (Cherry)
# - mon-node-${HOST_ID}.cothrom.ie -> http://node_exporter:9100 (M4)
# - mon-blackbox-${HOST_ID}.cothrom.ie -> http://blackbox_exporter:9115 (M4)
# TUNNEL_TOKEN=

# -----------------------------------------------------------------------------
# Vimeo / ffprobe exporter — for later (G2), not used by M1 Compose
# Auth pattern and working API examples: docs/developer/ffmpeg-vimeo.md
# -----------------------------------------------------------------------------
# VIMEO_TOKEN=
# VIMEO_KEY=
# VIMEO_SECRET=
# VIMEO_EVENTID=
# DEVICE_NAME=encoder01
