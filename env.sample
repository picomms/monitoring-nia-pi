TZ=Europe/Dublin
HOST_ID=cherry

# Image pins (override only when upgrading intentionally)
PROMETHEUS_VERSION=v3.13.1
GRAFANA_VERSION=13.0
NODE_EXPORTER_VERSION=v1.12.0
CLOUDFLARED_VERSION=2026.7.1

# Published ports (LAN access)
PROMETHEUS_PORT=9090
GRAFANA_PORT=3000

# Grafana
GF_ADMIN_USER=admin
GF_ADMIN_PASSWORD=changeme
# LAN fallback used when GRAFANA_ROOT_URL is unset.
GRAFANA_HOST=localhost
# Public URL used behind Cloudflare Tunnel / Access.
GRAFANA_ROOT_URL=https://mon-grafana.cothrom.ie

# Cloudflare Tunnel for Grafana only (enable with: just up-tunnel)
# - mon-grafana.cothrom.ie -> http://grafana:3000
# Slice scrapes use Tailscale MagicDNS (not Cloudflare). See prometheus/targets/.
# TUNNEL_TOKEN=

# Speedtest Tracker (linuxserver) — UI :8765, metrics /prometheus
# Generate key:
#   docker run --rm --entrypoint php lscr.io/linuxserver/speedtest-tracker:1.14.5 artisan key:generate --show
SPEEDTEST_TRACKER_VERSION=1.14.5
SPEEDTEST_PORT=8765
SPEEDTEST_APP_KEY=
SPEEDTEST_APP_URL=http://cherry.taild08b87.ts.net:8765
SPEEDTEST_SCHEDULE=0 */6 * * *
# SPEEDTEST_SERVERS=
# PROMETHEUS_ENABLED=true is set in compose (first boot only).
# If /prometheus 404s after first boot: Settings → Data platforms → enable Prometheus,
# or SQL: UPDATE settings SET payload='true' WHERE name='prometheus_enabled';
