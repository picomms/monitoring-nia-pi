# Per-host identity — used when creating DNS / Public Hostname rows in Zero Trust.
# Examples: pi1, pi2, pi3
HOST_ID=pi1

# Remotely managed Cloudflare Tunnel token for this host (required).
# Tunnel name convention: monitoring-slice-<HOST_ID>
TUNNEL_TOKEN=

# Image pins (override only when upgrading intentionally)
CLOUDFLARED_VERSION=2026.7.1
NODE_EXPORTER_VERSION=v1.12.0
BLACKBOX_EXPORTER_VERSION=v0.28.0

# -----------------------------------------------------------------------------
# Hostname contract (cothrom.ie — mon-* prefix for Universal SSL)
# Create these Public Hostnames on this host's tunnel:
#   mon-node-${HOST_ID}.cothrom.ie      → http://node_exporter:9100
#   mon-blackbox-${HOST_ID}.cothrom.ie  → http://blackbox_exporter:9115
# Full runbook: https://picomms.github.io/monitoring-nia-pi/cloudflare/
# -----------------------------------------------------------------------------
